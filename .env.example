# API Configuration (OpenAI-compatible)
# Supports DeepSeek, MiMo, OpenAI, or any compatible endpoint

OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Alternative configurations:
# DeepSeek: OPENAI_BASE_URL=https://api.deepseek.com/v1, LLM_MODEL=deepseek-chat
# OpenAI: OPENAI_BASE_URL=https://api.openai.com/v1, LLM_MODEL=gpt-4o-mini
# MiMo: OPENAI_BASE_URL=https://api.mimo.ai/v1, LLM_MODEL=mimo-chat
